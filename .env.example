# --- General ---
SECRET_KEY=cambia-esto-en-produccion
FLASK_DEBUG=0
CORS_ORIGINS=*

# --- Base de datos ---
# Local con docker-compose:
DATABASE_URL=postgresql+psycopg2://trivia:trivia@db:5432/trivia
# Desarrollo sin Docker (SQLite):
# DATABASE_URL=sqlite:///trivia.db

# --- Autenticación ---
# local   -> login propio (/api/v1/auth/login) con JWT HS256. Ideal para desarrollo.
# cognito -> valida tokens RS256 emitidos por AWS Cognito (JWKS).
AUTH_MODE=local
JWT_SECRET=cambia-esto-tambien
JWT_EXPIRES_MIN=480

# --- AWS Cognito (solo si AUTH_MODE=cognito) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# --- Seeds ---
# Si =1, docker-compose crea tablas y datos de ejemplo al arrancar
SEED_ON_START=1
# Contraseña de los usuarios de ejemplo. Si se omite, se genera una
# aleatoria y se imprime una sola vez al ejecutar el seed.
SEED_DEFAULT_PASSWORD=
